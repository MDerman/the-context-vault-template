{
  "export_root": "~/Code/vault-public",
  "manifest_name": "_master/system/bootstrap/state/export-manifest.json",
  "copy_obsidian": "exact",
  "context_folders": [
    {
      "source": "personal",
      "target": "personal",
      "public_home_description": [
        "This is your personal home for goals, tasks, routines, reflection, and durable life notes.",
        "Use it to keep personal plans and reference material separate from public brand or business work."
      ]
    },
    {
      "source": "personal-brand",
      "target": "personal-brand",
      "public_home_description": [
        "This is your personal-brand home for content ideas, audience notes, brand strategy, offers, CRM context, and publishing plans.",
        "Use it to keep public-facing strategy and creative work separate from private personal notes."
      ]
    },
    {
      "source": "business",
      "target": "business",
      "public_home_description": [
        "This is your business home for tasks, projects, team notes, leads, resources, and operating docs.",
        "Use it for company work that needs structure without mixing into personal or personal-brand material."
      ]
    }
  ],
  "public_context_scaffold_dirs": {
    "business": [
      "meetings/1-on-1s",
      "meetings/general-meetings",
      "meetings/customer-calls",
      "meetings/founder-notes",
      "product/specs",
      "product/decisions",
      "product/experiments",
      "product/user-signals",
      "gtm/campaigns",
      "gtm/offers",
      "gtm/icp",
      "gtm/competitors",
      "ops/metrics-snapshots",
      "ops/sops",
      "skills"
    ]
  },
  "root_files": [
    "AGENTS.md",
    {
      "source": "_master/system/bootstrap/bootstrap-public-README.md",
      "target": "README.md"
    },
    {
      "source": "_master/system/bootstrap/install.sh",
      "target": "install.sh"
    },
    {
      "source": ".agents/skills/.gitkeep",
      "target": ".agents/skills/.gitkeep"
    }
  ],
  "root_dirs": [
    ".agents/skills"
  ],
  "root_symlinks": {
    "CLAUDE.md": "AGENTS.md",
    ".claude/skills": "../.agents/skills"
  },
  "generated_exclude_paths": [
    "_master/Dashboard.md",
    "_master/system/context/01-Context.md",
    "_master/system/context/02-Identity.md",
    "_master/system/context/03-Momentum.md",
    "_master/system/context/CONTEXT.md",
    "_master/system/context/context.json"
  ],
  "generated_exclude_globs": [
    "_master/_obsidian/periodic/**",
    "_master/_obsidian/attachments/**",
    "_master/agents/skill-packs/**",
    "_master/agents/skills/manual/**",
    "_master/agents/skills/personal-folder-structure/**",
    "_master/agents/skills-dump/**",
    "_master/system/context/2026*.md",
    "_master/system/backup/**",
    "_master/system/inbox/**",
    "_master/system/local/**",
    "_master/backup-and-sync/**",
    "_master/general-tools/gmail-invoice-collector/**",
    "_master/general-tools/invoice-generation/**"
  ],
  "global_exclude_names": [
    ".DS_Store",
    "__pycache__"
  ],
  "repo_preserve_names": [
    ".git",
    ".github",
    ".gitignore",
    ".gitattributes",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "LICENSE.md"
  ],
  "sensitive_exclude_names": [
    ".env",
    ".env.base",
    ".gcal-token.json",
    "secrets",
    "secret",
    "kubeconfig"
  ],
  "obsidian_exclude_globs": [
    ".obsidian/text-generator.json",
    ".obsidian/plugins/context-nine/data.json",
    ".obsidian/plugins/obsidian-textgenerator-plugin/data.json",
    ".obsidian/plugins/share-note/data.json",
    ".obsidian/plugins/system3-relay/data.json",
    ".obsidian/plugins/system3-relay/relay.log*",
    ".obsidian/plugins/system3-relay/relay*.log*",
    ".obsidian-mobile/plugins/system3-relay/data.json",
    ".obsidian-mobile/plugins/system3-relay/relay.log*",
    ".obsidian-mobile/plugins/system3-relay/relay*.log*",
    ".obsidian/plugins/terminal/data.json",
    ".obsidian/plugins/todoist-sync-plugin/data.json"
  ],
  "obsidian_plugin_exact_copy_plugins": [
    "context-nine",
    "simple-folder-note",
    "system3-relay"
  ],
  "obsidian_plugin_public_files": [
    "data.json",
    "manifest.json",
    "styles.css"
  ],
  "text_rewrite_suffixes": [
    ".base",
    ".css",
    ".json",
    ".md",
    ".py",
    ".sh",
    ".toml",
    ".txt",
    ".yaml",
    ".yml",
    ".zsh"
  ]
}

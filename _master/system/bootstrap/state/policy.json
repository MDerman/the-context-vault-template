{
  "schema_version": 1,
  "default_action": "preserve",
  "actions": {
    "preserve": [
      ".git",
      ".git/**",
      "_master/system/bootstrap/state/install.json",
      "_master/system/bootstrap/state/upgrade-reports/**",
      "*/*.md",
      "*/brand-strategy-and-vision/**",
      "*/_obsidian/content/content-cadence.json",
      "*/_obsidian/tasks/**",
      "*/_obsidian/projects/**",
      "*/_obsidian/epics/**",
      "*/_obsidian/content/**",
      "*/_obsidian/content-schedules/**",
      "*/_obsidian/periodic/**",
      "_library/**",
      "_wiki/**",
      "other/**"
    ],
    "migrate": [
      "*/_obsidian/tasks/*.md",
      "*/_obsidian/tasks/**/*.md"
    ],
    "create_if_missing": [
      "personal/personal.md",
      "personal-brand/personal-brand.md",
      "business/business.md",
      "*/_obsidian/bases/*.base",
      "*/_obsidian/bases/**/*.base",
      "*/_obsidian/templates/*.md",
      "*/_obsidian/templates/**/*.md",
      "*/_obsidian/excalidraw/**"
    ],
    "replace": [
      "README.md",
      "install.sh",
      "AGENTS.md",
      "CLAUDE.md",
      ".agents/**",
      ".claude/**",
      ".bootstrap-export-manifest.json",
      ".vault-bootstrap/policy.json",
      ".vault-bootstrap/release.json",
      ".obsidian/app.json",
      ".obsidian/appearance.json",
      ".obsidian/community-plugins.json",
      ".obsidian/community-plugins.full-desktop.json",
      ".obsidian/core-plugins.json",
      ".obsidian/daily-notes.json",
      ".obsidian/graph.json",
      ".obsidian/hotkeys.json",
      ".obsidian/snippets/**",
      ".obsidian/themes/**",
      ".obsidian/plugins/*/main.js",
      ".obsidian/plugins/*/manifest.json",
      ".obsidian/plugins/*/styles.css",
      "_master/**"
    ]
  },
  "migrations": [
    {
      "path": "_master/system/bootstrap/install_plugins.py"
    },
    {
      "path": "_master/system/migrations/2026_05_30_context_folder_notes.py"
    }
  ]
}

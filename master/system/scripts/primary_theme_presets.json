{
  "version": 1,
  "default_preset": "current-local",
  "presets": {
    "current-local": {
      "description": "Current local Primary dark palette and current Primary Style Settings.",
      "comments": [
        "Calmer local Primary dark mode: darker panels, brighter low-chroma text.",
        "File/sidebar background color: hsla(24, 8%, 8%, 1). In Style Settings, use that value for editor background if you want the editor to match the file/folder panel background."
      ],
      "scrollbar_track": "hsla(24, 8%, 8%, 1)",
      "scrollbar_thumb": "var(--scrollbar-thumb-bg)",
      "theme_dark_variables": [
        ["--color-d-gray-10", "hsla(32, 20%, 88%, 1)"],
        ["--color-d-gray-20", "hsla(34, 16%, 78%, 1)"],
        ["--color-d-gray-30", "hsla(34, 12%, 70%, 1)"],
        ["--color-d-gray-40", "hsla(35, 10%, 58%, 1)"],
        ["--color-d-gray-50", "hsla(34, 10%, 48%, 1)"],
        ["--color-d-gray-60", "hsla(33, 11%, 34%, 1)"],
        ["--color-d-gray-70", "hsla(31, 11%, 25%, 1)"],
        ["--color-d-gray-80", "hsla(28, 9%, 18%, 1)"],
        ["--color-d-gray-90", "hsla(33, 8%, 14%, 1)"],
        ["--color-d-gray-100", "hsla(30, 8%, 12%, 1)"],
        ["--color-d-gray-110", "hsla(30, 7%, 10%, 1)"],
        ["--color-d-gray-120", "hsla(29, 6%, 9%, 1)"],
        ["--color-d-gray-130", "hsla(24, 8%, 8%, 1)"],
        ["--color-d-gray-140", "hsla(32, 8%, 6%, 1)"],
        ["--color-d-alpha-gray", "hsla(34, 6%, 42%, 0.2)"],

        ["--background-primary", "var(--color-d-gray-110)"],
        ["--background-primary-alt", "var(--color-d-gray-120)"],
        ["--background-secondary", "var(--color-d-gray-130)"],
        ["--background-secondary-alt", "var(--color-d-gray-130)"],
        ["--scrollbar-bg", "var(--color-d-gray-130)"],

        ["--background-modifier-border", "var(--color-d-gray-80)"],
        ["--background-modifier-border-hover", "color-mix(in srgb, var(--color-d-gray-70) 40%, var(--color-d-gray-80))"],
        ["--background-modifier-border-focus", "color-mix(in srgb, var(--color-d-gray-70) 40%, var(--color-d-gray-80))"],

        ["--text-normal", "hsla(32, 18%, 78%, 1)"],
        ["--text-muted", "hsla(34, 11%, 62%, 1)"],
        ["--text-faint", "hsla(35, 9%, 52%, 1)"],

        ["--icon-color", "color-mix(in srgb, var(--color-d-gray-50) 70%, var(--color-d-gray-40))"],
        ["--icon-color-hover", "var(--color-d-gray-30)"],
        ["--icon-color-focused", "var(--color-d-gray-30)"],
        ["--icon-color-active", "var(--color-d-gray-20)"],

        ["--titlebar-text-color", "var(--color-d-gray-50)"],
        ["--titlebar-text-color-focused", "var(--color-d-gray-40)"],
        ["--status-bar-item-color", "var(--color-d-gray-40)"],
        ["--status-bar-item-color-hover", "var(--color-d-gray-20)"],
        ["--vault-name-color", "var(--color-d-gray-30)"],
        ["--vault-name-color-hover", "var(--color-d-gray-20)"],

        ["--nav-item-color", "var(--color-d-gray-30)"],
        ["--nav-item-color-hover", "var(--color-d-gray-20)"],
        ["--nav-item-color-active", "var(--color-d-gray-20)"],
        ["--nav-heading-color", "var(--color-d-gray-40)"],
        ["--nav-heading-color-hover", "var(--color-d-gray-30)"],

        ["--tab-text-color", "var(--text-faint)"],
        ["--tab-text-color-active", "var(--text-muted)"],
        ["--tab-text-color-focused", "var(--text-muted)"],
        ["--tab-text-color-focused-active", "var(--text-muted)"],
        ["--tab-text-color-focused-active-current", "var(--text-normal)"],

        ["--editor-bg-color", "var(--background-primary)"],
        ["--blockquote-background-color", "var(--color-d-gray-120)"],
        ["--modal-background", "var(--background-primary)"],
        ["--background-modifier-form-field", "var(--color-d-gray-130)"],
        ["--text-input-color", "var(--text-normal)"],
        ["--text-input-color-focused", "var(--text-normal)"]
      ],
      "style_settings": {
        "primary-theme@@colorful-folders_text": false,
        "primary-theme@@colorful-folders_collapse-indicator": true,
        "primary-theme@@colorful-folders_background": false,
        "primary-theme@@alt-folder-icons": false,
        "primary-theme@@colorful-folders_inherit-color": true,
        "primary-theme@@colorful-folders_indentation-guide": true,
        "primary-theme@@zero-popup-popdown": true,
        "primary-theme@@zero-popup-blur": true,
        "primary-theme@@ribbon-background@@dark": "#1A120B",
        "primary-theme@@active-line-highlight": true,
        "primary-theme@@active-line-bg@@dark": "#1E1C1A",
        "primary-theme@@status-bar-background@@dark": "#191511",
        "primary-theme@@editor-border-color@@dark": "#342A23",
        "primary-theme@@nav-folder-1-color@@dark": "#FFFFFF00",
        "primary-theme@@nav-folder-1-bg-color@@dark": "#192C33",
        "primary-theme@@nav-folder-2-bg-color@@dark": "#20261E",
        "primary-theme@@nav-folder-3-bg-color@@dark": "#191D25",
        "primary-theme@@nav-folder-4-bg-color@@dark": "#1B1C1D",
        "primary-theme@@nav-folder-5-bg-color@@dark": "#2C2721",
        "primary-theme@@nav-folder-7-bg-color@@dark": "#231D28",
        "primary-theme@@nav-folder-8-bg-color@@dark": "#1D1D1D",
        "primary-theme@@nav-folder-9-bg-color@@dark": "#282828",
        "primary-theme@@nav-folder-10-bg-color@@dark": "#1E2429",
        "primary-theme@@nav-folder-11-bg-color@@dark": "#291D1F",
        "primary-theme@@nav-folder-12-bg-color@@dark": "#222024",
        "primary-theme@@editor-border-width": "1px",
        "primary-theme@@editor-bg-color@@dark": "#161413"
      }
    },
    "atom-one-dark": {
      "description": "Atom One Dark-inspired Primary dark palette using VS Code Atom colors.",
      "comments": [
        "Atom One Dark-inspired local Primary dark mode.",
        "Core editor and UI surfaces are flattened to the editor background color for a low-contrast Atom One Dark experiment."
      ],
      "scrollbar_track": "#141414",
      "scrollbar_thumb": "#ffffff20",
      "theme_dark_variables": [
        ["--color-d-gray-10", "#f0f0f0"],
        ["--color-d-gray-20", "#dcdcdc"],
        ["--color-d-gray-30", "#d7dae0"],
        ["--color-d-gray-40", "#bfbfbf"],
        ["--color-d-gray-50", "#8a8a8a"],
        ["--color-d-gray-60", "#757575"],
        ["--color-d-gray-70", "#565656"],
        ["--color-d-gray-80", "#454545"],
        ["--color-d-gray-90", "#393939"],
        ["--color-d-gray-100", "#202020"],
        ["--color-d-gray-110", "#1e1e1e"],
        ["--color-d-gray-120", "#181818"],
        ["--color-d-gray-130", "#141414"],
        ["--color-d-gray-140", "#101010"],
        ["--color-d-alpha-gray", "#9E9E9E2f"],

        ["--background-primary", "#141414"],
        ["--background-primary-alt", "#141414"],
        ["--background-secondary", "#141414"],
        ["--background-secondary-alt", "#141414"],
        ["--scrollbar-bg", "#141414"],
        ["--scrollbar-thumb-bg", "#ffffff20"],
        ["--scrollbar-active-thumb-bg", "#ffffff35"],

        ["--background-modifier-border", "#535353"],
        ["--background-modifier-border-hover", "#77777750"],
        ["--background-modifier-border-focus", "#535353"],
        ["--background-modifier-form-field", "#232323"],

        ["--text-normal", "#bfbfbf"],
        ["--text-muted", "#b3b3b3"],
        ["--text-faint", "#7d7d7d"],
        ["--text-accent", "#61afef"],
        ["--text-accent-hover", "#4aa5f0"],
        ["--text-selection", "#9E9E9E2f"],
        ["--text-highlight-bg", "#bfbfbf26"],
        ["--text-error", "#c24038"],
        ["--text-warning", "#d19a66"],

        ["--icon-color", "#bfbfbf"],
        ["--icon-color-hover", "#ffffff"],
        ["--icon-color-focused", "#d7dae0"],
        ["--icon-color-active", "#f0f0f0"],

        ["--titlebar-background", "#141414"],
        ["--titlebar-background-focused", "#141414"],
        ["--titlebar-text-color", "#7d7d7d"],
        ["--titlebar-text-color-focused", "#b3b3b3"],
        ["--ribbon-background", "#141414"],
        ["--tab-container-background", "#141414"],
        ["--tab-background-active", "#141414"],
        ["--tab-background-active-hover", "#141414"],
        ["--tab-background-active-current", "#141414"],

        ["--status-bar-background", "#141414"],
        ["--status-bar-border-color", "#141414"],
        ["--status-bar-item-color", "#b3b3b3"],
        ["--status-bar-item-color-hover", "#d7dae0"],
        ["--vault-name-color", "#bfbfbf"],
        ["--vault-name-color-hover", "#f0f0f0"],

        ["--nav-item-color", "#bfbfbf"],
        ["--nav-item-color-hover", "#ffffff"],
        ["--nav-item-color-active", "#d7dae0"],
        ["--nav-item-background-hover", "#393939"],
        ["--nav-item-background-active", "#393939"],
        ["--nav-heading-color", "#bfbfbf"],
        ["--nav-heading-color-hover", "#d7dae0"],

        ["--tab-text-color", "#b3b3b3"],
        ["--tab-text-color-active", "#dcdcdc"],
        ["--tab-text-color-focused", "#dcdcdc"],
        ["--tab-text-color-focused-active", "#dcdcdc"],
        ["--tab-text-color-focused-active-current", "#f0f0f0"],
        ["--tab-outline-color", "#181818"],
        ["--tab-divider-color", "#181818"],

        ["--editor-bg-color", "#141414"],
        ["--blockquote-background-color", "#141414"],
        ["--blockquote-border-color", "#646464"],
        ["--modal-background", "#141414"],
        ["--background-modifier-hover", "#393939"],
        ["--background-modifier-active-hover", "#393939"],
        ["--interactive-normal", "#565656"],
        ["--interactive-hover", "#575757"],
        ["--interactive-accent", "#4d78cc"],
        ["--interactive-accent-hover", "#4d78cc"],
        ["--text-input-color", "#bfbfbf"],
        ["--text-input-color-focused", "#f0f0f0"],

        ["--color-red", "#e05561"],
        ["--color-orange", "#d19a66"],
        ["--color-yellow", "#d18f52"],
        ["--color-green", "#8cc265"],
        ["--color-cyan", "#42b3c2"],
        ["--color-blue", "#61afef"],
        ["--color-purple", "#c162de"]
      ],
      "extra_css": "\n.theme-dark.workspace,\n.theme-dark .workspace,\n.theme-dark .workspace-ribbon,\n.theme-dark .workspace-split,\n.theme-dark .workspace-tabs,\n.theme-dark .workspace-leaf,\n.theme-dark .workspace-leaf-content,\n.theme-dark .workspace-split.mod-left-split,\n.theme-dark .workspace-split.mod-right-split,\n.theme-dark .workspace-split.mod-root,\n.theme-dark .workspace-tab-container,\n.theme-dark .workspace-tab-header-container,\n.theme-dark .workspace-leaf-content .view-header,\n.theme-dark .workspace-leaf-content .view-content,\n.theme-dark .markdown-source-view,\n.theme-dark .markdown-reading-view,\n.theme-dark .markdown-preview-view {\n    background-color: #141414;\n}\n",
      "style_settings": {
        "primary-theme@@ribbon-background@@dark": "#141414",
        "primary-theme@@active-line-highlight": true,
        "primary-theme@@active-line-bg@@dark": "#101010",
        "primary-theme@@status-bar-background@@dark": "#141414",
        "primary-theme@@editor-border-color@@dark": "#535353",
        "primary-theme@@editor-border-width": "1px",
        "primary-theme@@editor-bg-color@@dark": "#141414"
      }
    }
  }
}

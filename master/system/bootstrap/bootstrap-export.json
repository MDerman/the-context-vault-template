{
  "export_root": "~/Code/vault-public",
  "manifest_name": ".bootstrap-export-manifest.json",
  "copy_obsidian": "exact",
  "master_env_mode": "empty-directory",
  "context_folders": [
    {
      "source": "01-personal",
      "target": "01-personal"
    },
    {
      "source": "02-personal-brand",
      "target": "02-personal-brand"
    },
    {
      "source": "03-business",
      "target": "03-business"
    }
  ],
  "root_files": [
    "AGENTS.md",
    {
      "source": "master/system/bootstrap/README-bootstrap.md",
      "target": "README.md"
    },
    {
      "source": "master/system/bootstrap/vault-bootstrap/policy.json",
      "target": ".vault-bootstrap/policy.json"
    },
    {
      "source": "master/system/bootstrap/vault-bootstrap/release.json",
      "target": ".vault-bootstrap/release.json"
    }
  ],
  "root_symlinks": {
    "CLAUDE.md": "AGENTS.md",
    ".agents/skills": "../master/agents/skills",
    ".claude/skills": "../.agents/skills"
  },
  "generated_exclude_paths": [
    "master/Dashboard.md",
    "master/system/context/00-StartHere.md",
    "master/system/context/01-Context.md",
    "master/system/context/02-Identity.md",
    "master/system/context/03-Momentum.md",
    "master/system/context/CONTEXT.md",
    "master/system/context/context.json"
  ],
  "generated_exclude_globs": [
    "master/_obsidian/periodic/**",
    "master/system/context/2026*.md",
    "master/system/backup/**",
    "master/system/inbox/**"
  ],
  "global_exclude_names": [
    ".DS_Store",
    "__pycache__"
  ],
  "repo_preserve_names": [
    ".git",
    ".github",
    ".gitignore",
    ".gitattributes",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "LICENSE.md"
  ],
  "sensitive_exclude_names": [
    ".env",
    ".env.base",
    ".gcal-token.json",
    "secrets",
    "secret",
    "kubeconfig"
  ],
  "obsidian_exclude_globs": [
    ".obsidian/text-generator.json",
    ".obsidian/plugins/context-nine/data.json",
    ".obsidian/plugins/obsidian-textgenerator-plugin/data.json",
    ".obsidian/plugins/share-note/data.json",
    ".obsidian/plugins/system3-relay/data.json",
    ".obsidian/plugins/terminal/data.json",
    ".obsidian/plugins/todoist-sync-plugin/data.json"
  ],
  "obsidian_plugin_full_copy_plugins": [
    "context-nine",
    "system3-relay"
  ],
  "obsidian_plugin_public_files": [
    "data.json",
    "manifest.json",
    "styles.css"
  ],
  "text_rewrite_suffixes": [
    ".base",
    ".css",
    ".json",
    ".md",
    ".py",
    ".sh",
    ".toml",
    ".txt",
    ".yaml",
    ".yml",
    ".zsh"
  ]
}

{
  "schema_version": 1,
  "default_action": "preserve",
  "actions": {
    "preserve": [
      ".git",
      ".git/**",
      "master/system/bootstrap/state/install.json",
      "master/system/bootstrap/state/upgrade-reports/**",
      "*/DECLARATION.md",
      "*/DECLARATION/**",
      "*/_obsidian/tasks/**",
      "*/_obsidian/projects/**",
      "*/_obsidian/epics/**",
      "*/_obsidian/content/**",
      "*/_obsidian/content-schedules/**",
      "*/_obsidian/periodic/**",
      "library/**",
      "wiki/**",
      "other/**"
    ],
    "migrate": [
      "*/_obsidian/tasks/*.md",
      "*/_obsidian/tasks/**/*.md"
    ],
    "create_if_missing": [
      "*/HOME.md",
      "*/_obsidian/bases/*.base",
      "*/_obsidian/bases/**/*.base",
      "*/_obsidian/templates/*.md",
      "*/_obsidian/templates/**/*.md",
      "*/_obsidian/excalidraw/**"
    ],
    "replace": [
      "README.md",
      "install.sh",
      "AGENTS.md",
      "CLAUDE.md",
      ".agents/**",
      ".claude/**",
      ".bootstrap-export-manifest.json",
      ".vault-bootstrap/policy.json",
      ".vault-bootstrap/release.json",
      ".obsidian/app.json",
      ".obsidian/appearance.json",
      ".obsidian/community-plugins.json",
      ".obsidian/community-plugins.full-desktop.json",
      ".obsidian/core-plugins.json",
      ".obsidian/daily-notes.json",
      ".obsidian/graph.json",
      ".obsidian/hotkeys.json",
      ".obsidian/snippets/**",
      ".obsidian/themes/**",
      ".obsidian/plugins/*/main.js",
      ".obsidian/plugins/*/manifest.json",
      ".obsidian/plugins/*/styles.css",
      "master/**"
    ]
  },
  "migrations": []
}

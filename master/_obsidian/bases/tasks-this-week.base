filters:
  and:
    - file.hasTag("task")
    - or:
        - scheduled >= today() && scheduled <= today() + "7d"
        - due >= today() && due <= today() + "7d"
views:
  - type: table
    name: This Week
    order:
      - file.name
      - status
      - priority
      - scheduled
      - due
      - contexts

filters:
  and:
    - type == "epic"
    - or:
        - file.inFolder("01-personal/_obsidian/epics")
        - file.inFolder("02-personal-brand/_obsidian/epics")
        - file.inFolder("03-business/_obsidian/epics")
views:
  - type: table
    name: Active Epics
    order:
      - file.name
      - status
      - contexts
      - file.folder
